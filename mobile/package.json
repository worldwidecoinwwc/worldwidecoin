{
  "name": "worldwidecoin-mobile",
  "version": "1.0.0",
  "description": "WorldWideCoin cryptocurrency wallet for smart phones",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "xcodebuild -workspace ios/WorldWideCoin.xcworkspace -scheme WorldWideCoin -configuration Release -destination generic/platform=iOS -archivePath ios/build/WorldWideCoin.xcarchive archive"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.72.6",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/stack": "^6.3.20",
    "react-native-screens": "^3.25.0",
    "react-native-safe-area-context": "^4.7.4",
    "react-native-gesture-handler": "^2.13.4",
    "@react-native-async-storage/async-storage": "^1.19.5",
    "react-native-biometrics": "^3.0.1",
    "react-native-camera": "^4.2.1",
    "react-native-qrcode-scanner": "^1.5.5",
    "react-native-qrcode-svg": "^6.2.0",
    "react-native-svg": "^13.14.0",
    "react-native-vector-icons": "^10.0.2",
    "react-native-paper": "^5.11.1",
    "react-native-push-notification": "^8.1.1",
    "react-native-keychain": "^8.1.3",
    "react-native-fs": "^2.20.0",
    "react-native-share": "^9.4.1",
    "axios": "^1.6.2",
    "crypto-js": "^4.2.0",
    "web3": "^4.3.0",
    "@ethersproject/ethers": "^5.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@tsconfig/react-native": "^3.0.0",
    "@types/react": "^18.0.24",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.2.1",
    "eslint": "^8.19.0",
    "jest": "^29.2.1",
    "metro-react-native-babel-preset": "0.76.8",
    "prettier": "^2.4.1",
    "react-test-renderer": "18.2.0",
    "typescript": "4.8.4"
  },
  "jest": {
    "preset": "react-native"
  },
  "keywords": [
    "worldwidecoin",
    "cryptocurrency",
    "wallet",
    "blockchain",
    "mining",
    "react-native",
    "mobile"
  ],
  "author": "WorldWideCoin Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/worldwidecoinwwc/worldwidecoin.git"
  },
  "bugs": {
    "url": "https://github.com/worldwidecoinwwc/worldwidecoin/issues"
  },
  "homepage": "https://worldwidecoinwwc.github.io/worldwidecoin/"
}
